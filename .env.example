# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
RECIPIENTS_CSV_URI=gs://your-bucket/path/to/recipients.csv
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=alerts@simbyp.org
FROM_NAME=SIMBYP Alertas

# Email Recipients (comma-separated) - fallback if CSV not available
GFW_RECIPIENTS=recipient1@example.com,recipient2@example.com
PSA_RECIPIENTS=recipient1@example.com
AREA_CONSTRUIDA_RECIPIENTS=recipient1@example.com
DIGEST_RECIPIENTS=recipient1@example.com

# Service Configuration
DAYS_BACK=7
PORT=8080