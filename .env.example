# Local Development Configuration
# ============================================================================
# IMPORTANT: Non-secret defaults are defined in src/config.py
# Only override values here if needed for local testing
#
# PRODUCTION: Use environment variables via `gcloud run deploy --set-env-vars`
#            and Google Secret Manager for secrets.
#            See GCP_DEPLOYMENT.md for instructions.
# ============================================================================

# REQUIRED: Azure AD Credentials for Microsoft Graph API (SECRETS ONLY)
# Never commit real keys to git - use Secret Manager in production
AZURE_CLIENT_ID=your-azure-client-id-here
AZURE_TENANT_ID=your-azure-tenant-id-here
AZURE_CLIENT_SECRET=your-azure-client-secret-here

# REQUIRED: Database configuration (PostgreSQL is required)
# The application now requires a PostgreSQL database for recipient management.
# Example formats:
#   - Local: postgresql://user:password@localhost:5432/simbyp
#   - Cloud SQL (Unix socket): postgresql://user:pass@/db?host=/cloudsql/project:region:instance
#   - Cloud SQL (Private IP): postgresql://user:pass@10.0.0.1:5432/db
DATABASE_URL=postgresql://user:password@localhost:5432/simbyp

# OPTIONAL: Google service account key for local development
# (Not needed in GCP Cloud Run - service account is automatic)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# OPTIONAL: Override application defaults (only if needed)
# Defaults from src/config.py:
#
# GCP_PROJECT_ID=bosques-bogota-416214
# FROM_EMAIL=simbyp@sdp.gov.co
# FROM_NAME=SIMBYP Alertas
# DAYS_BACK=20
# PORT=8080

